BACKEND_PORT=3333
FRONTEND_PORT=3000

# API URL used by the frontend build. When using nginx reverse-proxy with '/api' mapped to backend,
# leave this empty or set to '/api'
NEXT_PUBLIC_API_URL=/api

# Public API key (used by frontend for public endpoints)
NEXT_PUBLIC_API_KEY=ifpa_public_api_key_2025


# Database configuration (used by docker-compose and application)
# NOTE: If the MySQL container has an existing volume created with a different root password,
# changing these values will NOT update the running database credentials. To reinitialize the
# database with these values you must remove the DB volume (data loss) and recreate the stack.
DB_DATABASE=repo_ifpa
DB_USER=ifpa
DB_PASSWORD=Admin_repo@
DB_ROOT_PASSWORD=repo2026@
MYSQL_ROOT_PASSWORD=repo2026@

# Configurações JWT
JWT_SECRET=repo_ifpa_secret_2025
JWT_EXPIRY=12h


# API Key para acesso público aos endpoints
API_KEY=ifpa_public_api_key_2025


SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=repo.ifpa@gmail.com
SMTP_PASS=bjgp lpkj xgtz ejlo

FROM_EMAIL=repo.ifpa@gmail.com
